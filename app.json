{
  "expo": {
    "name": "Shekhar Raja Jewellers",
    "slug": "srj-jewellers",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-camera",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#6B21A8"
        }
      ],
      "expo-barcode-scanner"
    ],
    "splash": {
      "image": "./assets/images/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B21A8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shekharraja.jewellers",
      "infoPlist": {
        "NSCameraUsageDescription": "Shekhar Raja Jewellers uses the camera to scan jewellery pieces and QR tags.",
        "NSMicrophoneUsageDescription": "Microphone access is required by the camera."
      }
    },
    "android": {
      "package": "com.shekharraja.jewellers",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#6B21A8",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/app-icon.png"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "e79f1753-a229-4e5e-84ff-7c559cb6219b"
      }
    },
    "owner": "rahul95824832"
  }
}
