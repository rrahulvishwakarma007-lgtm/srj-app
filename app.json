{
  "expo": {
    "name": "Shekhar Raja Jewellers",
    "slug": "srj-jewellers",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-camera",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#6B21A8"
        }
      ]
    ],
    "splash": {
      "image": "./assets/images/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B21A8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shekharraja.jewellers",
      "infoPlist": {
        "NSCameraUsageDescription": "Shekhar Raja Jewellers uses the camera to scan jewellery and try pieces virtually.",
        "NSMicrophoneUsageDescription": "Microphone access is required by the camera.",
        "NSPhotoLibraryUsageDescription": "Shekhar Raja Jewellers needs access to your photos to scan jewellery images.",
        "NSPhotoLibraryAddUsageDescription": "Shekhar Raja Jewellers needs access to save jewellery photos."
      }
    },
    "android": {
      "package": "com.shekharraja.jewellers",
      "versionCode": 6,
      "adaptiveIcon": {
        "backgroundColor": "#6B21A8",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/app-icon.png"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
      
      }
    }
  }
}
